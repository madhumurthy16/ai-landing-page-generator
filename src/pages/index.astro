---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="app-container">
		<div class="app-header">
			<h1 class="heading-one app-header-logo">PageCraftAI</h1>
			<p class="font-xsmall app-header-badge">Free tier — 20 pages/month</p>
		</div>

		<div class="app-body">
			<main>
				<section class="form-panel">
					<div class="form-panel-header">
						<h2 class="heading-two form-panel-title">Describe your product</h2>
						<p class="body-large form-panel-subtitle">Fill in the fields below and we'll generate a complete, professional landing page in seconds.</p>
					</div>
					<div class="form-divider"></div>
					<form>
						<div class="form-group">
							<label for="product-name" class="font-small field-label">Product Name<span class="font-xsmall required-field">Required</span></label>
							<input id="product-name" class="font-medium" placeholder = "What is the name of your product" type="text" />
						</div>
						<div class="form-group">
							<label for="product-desc" class="font-small field-label">Product Description <span class="font-xs required-field">Required</span></label>
							<textarea id="product-desc" class="font-medium" placeholder="Provide a one sentence description of the product" />
						</div>
						<div class="form-group">
							<label for="target-audience" class="font-small field-label">Target Audience <span class="font-xsmall required-field">Required</span></label>
							<input id="target-audience"  class="font-medium" placeholder="Who is your target audience?" type="text" />
						</div>
						<div class="form-group">
                            <fieldset>
								<span class="font-xsmall required-field">Required</span>
                                <legend class="font-small field-label">Key Benefits</legend>
                                <div class="benefits-row">
                                    <div class="benefits-row-one">
                                        <label  for="key-benefits-one" class="font-small visually-hidden">Key Benefit 1</label>
                                        <input id="key-benefits-one" class="font-medium" placeholder="Key Benefit 1" />
                                    </div>
                                    <div class="benefits-row-two">
                                        <label  for="key-benefits-two" class="font-small visually-hidden">Key Benefit 2</label>
                                        <input id="key-benefits-two" class="font-medium" placeholder="Key Benefit 2" />
                                        
                                    </div>
                                    <div class="benefits-row-three">
                                        <label  for="key-benefits-three" class="font-small visually-hidden">Key Benefit 3</label>
                                        <input id="key-benefits-three" class="font-medium" placeholder="Key Benefit 3" />
                                    </div>
                                </div>
                            </fieldset>
                        </div>  

						<div class="form-group">
							<label for="tone-of-voice" class="font-small field-label">Tone of Voice</label>
							<select class="form-select font-medium">
								<option selected>Professional</option>
								<option>Friendly & Conversational</option>
								<option>Bold & Urgent</option>
								<option>Playful & Witty</option>
								<option>Minimalist & Premium</option>
							</select>
						</div>
						
						<button class="btn-primary font-btn">Generate My Landing Page</button>
						<div class="btn-secondary-row">
							<button class="btn-success">Copied</button>
							<button class="btn-secondary">Download .html</button>
						</div>
					</form>
				</section>
				<!-- <section class="preview-panel">
					<div class="preview-label">
						<p class="font-small">Live preview</p>
					</div>
					<div class="preview-url-bar">
						<div class="preview-url-bar"></div>
						<p class="preview-url-text"></p>
					</div>
					<div class="preview-window">
						<div class="preview-window-hero">
							<p class="preview-hero-eyebrow"></p>
							<h2 class="preview-hero-title"></h2>
							<p class="preview-hero-desc"></p>
							<button class="btn-primary font-btn">Get Started Free</button>
						</div>
						<div class="preview-benefits">
							<p class="benefits-title font-medium font-medium-bold"></p>
							<div class="preview-cards">
								<div class="preview-card">
									<h4 class="heading-four"></h4>
									<p class="font-xsmall"></p>
								</div>
								<div class="preview-card">
									<h4 class="heading-four"></h4>
									<p class="font-xsmall"></p>
								</div>
								<div class="preview-card">
									<h4 class="heading-four"></h4>
									<p class="font-xsmall"></p>
								</div>
							</div>
						</div>
						<div class="preview-cta-strip">
							<p class="preview-cta-text"></p>
							<button class="preview-cta-text">Get Started Free</button>
						</div>
					</div>
				</section> -->
				<section class="preview-panel">
					<iframe id="previewFrame" class="preview-frame"></iframe>
				</section>
			</main>
		</div>
	</div>

</Layout>

<style>
	.app-container {
		margin: 4rem 4rem;
		background: #FFFFFF;
		border: 1.5px solid var(--gray-200);
		border-radius: 10px;
		overflow: hidden;
	}

	.app-header {
		background-color: var(--primary-indigo-900);
		padding: 12px 16px;
		display: flex;
		justify-content: center;
	}

	.app-header-logo {
		color: #FFFFFF;
	}

	.app-header-badge {
		display: none;
	}

	.app-body {
		padding: 16px 18px;
	}

	.form-panel {
		margin-bottom: 16px;
	}

	.form-panel-title {
		margin-bottom: 16px;

	}

	.form-panel-subtitle {
		margin-bottom: 16px;
	}

	.required-field {
		display: none;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		margin-bottom: 16px;
	}

	.field-label {
		margin-bottom: 8px;
	}

	fieldset {
		border: 0;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	#key-benefits-one,
	#key-benefits-two {
		margin-bottom: 8px;
	}

	
	/* Media Queries */

	@media screen(min-width: 768px) {
		box-shadow: 0 2px 16px rgba(15, 27, 76, .07);
		border-radius: 14px;
	}
</style>

